      "postman",
      "api",
      "testing",
      "collections"
    ],
    "maintainerType": "official",
    "license": "Apache-2.0",
    "verifiedAt": "2026-05-27",
    "popularityRank": 64,
    "installRate": 0.12,
    "iconUrl": "icons/postman.svg",
    "brand": {
      "logoBackground": "#ffffff",
      "logoForeground": "#ff6c37"
    },
    "auth": {
      "method": "api-key",
      "providerName": "Postman",
      "providerSignupUrl": "https://postman.co/settings/me/api-keys"
    },
    "toolGroups": [
      {
        "label": "Workspaces",
        "count": 3
      },
      {
        "label": "Collections",
        "count": 5
      },
      {
        "label": "Environments",
        "count": 3
      },
      {
        "label": "API Specs",
        "count": 3
      }
    ],
    "setupGuide": {
      "path": "guides/com.postman-postman-mcp.md",
      "estimatedMinutes": 2,
      "stepCount": 2
    },
    "platforms": [
      "macos",
      "windows",
      "linux"
    ],
    "minWaylandVersion": "0.8.0"
  }
}
