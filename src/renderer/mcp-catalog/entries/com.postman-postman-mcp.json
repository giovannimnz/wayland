{
  "$schema": "../schema/entry.schema.json",
  "name": "com.postman/postman-mcp",
  "title": "Postman",
  "description": "Connect AI agents to your Postman workspaces, collections, environments, and API specs for testing and automation.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/postmanlabs/postman-mcp-server",
  "repository": {
    "url": "https://github.com/postmanlabs/postman-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@postman/postman-mcp-server",
      "version": "2.8.9",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSTMAN_API_KEY",
          "description": "API key from your Postman account (Settings → API keys).",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "x-wayland": {
    "tier": "builder",
    "categories": [
      "api-testing",
      "developer"
    ],
