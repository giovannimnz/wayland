+  'atius:postinstall-hook': 'bash scripts/atius-postinstall-hook.sh',
+  'atius:update': 'bash scripts/atius-update.sh',
+};
+fs.writeFileSync(currentPath, JSON.stringify(upstream, null, 2) + '\n');
