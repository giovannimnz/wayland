+#!/usr/bin/env bash
+set -euo pipefail
+ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+BUN_BIN="/opt/Wayland/resources/bundled-bun/linux-arm64/bun"
+NODE_BIN="/usr/local/bin/node"
+CARGO_BIN="/home/ubuntu/.cargo/bin/cargo"
+UBUNTU_HOME="/home/ubuntu"
